# ═══════════════════════════════════════════════════════════
# ArmyClaw — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── Optional ─────────────────────────────────────────────

# Data directory for SQLite database and task artifacts
# Default: ./data
# ARMYCLAW_DATA_DIR=./data

# Maximum concurrent engineer agents
# Default: 5
# MAX_ENGINEERS=5

# Daily LLM spending budget in USD (blocks new calls when exceeded)
# Default: 50
# DAILY_BUDGET_USD=50

# Maximum agentic loop turns per agent run
# Default: 50
# MAX_AGENT_TURNS=50

# War Room (Sand Table) HTTP server port
# Default: 3939
# WAR_ROOM_PORT=3939

# ─── Lark Channel ───────────────────────────────────────────
# Get credentials from https://open.larksuite.com
# Run `npm run setup:lark` for interactive configuration.

# Connection mode: 'websocket' (default, no public URL needed) or 'webhook'
# LARK_CONNECTION_MODE=websocket

# Required (both must be set to activate Lark channel)
# LARK_APP_ID=cli_xxxxxxxxxx
# LARK_APP_SECRET=

# Event subscription verification
# LARK_VERIFICATION_TOKEN=
# LARK_ENCRYPT_KEY=

# Webhook server
# Default: 3003
# LARK_WEBHOOK_PORT=3003
# LARK_WEBHOOK_PATH=/webhook/event

# DM policy: 'allowlist' (default) or 'open'
# LARK_DM_POLICY=allowlist
# Comma-separated user IDs allowed to DM the bot
# LARK_ALLOW_FROM=4cd122cd,4d8a7eab

# Require @mention in group chats (default: true)
# LARK_REQUIRE_MENTION=true
